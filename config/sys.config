[
  {eturnal, [
    % Security and Realm Settings
    {secret, [<<"ErpUnoTurnSecret2026">>]},
    {realm, <<"rtp.erp.uno">>},
    {software_name, <<"eturnal">>},
    {strict_expiry, false},
    {credentials, #{}},

    % Listener Configuration (using 5-tuples)
    {listen, [
      {{0, 0, 0, 0}, 3478, udp, false, true},
      {{0, 0, 0, 0}, 3478, tcp, false, true}
    ]},

    % Relay Configuration
    {relay_min_port, 49152},
    {relay_max_port, 65535},
    {relay_ipv4_addr, undefined},
    {relay_ipv6_addr, undefined},

    % Logging & Rotations
    {log_dir, stdout},
    {log_level, info},
    {log_rotate_size, infinity},
    {log_rotate_count, 10},
    {run_dir, <<"run">>},

    % TLS / Encryption Settings
    {tls_crt_file, none},
    {tls_key_file, none},
    {tls_dh_file, none},
    {tls_options, <<"cipher_server_preference">>},
    {tls_ciphers, <<"HIGH:!aNULL:@STRENGTH">>},

    % Traffic & Limit Controls
    {max_allocations, 10},
    {max_permissions, 10},
    {max_bps, none},

    % Routing Controls & Filters
    {blacklist, []},
    {whitelist, []},
    {blacklist_clients, []},
    {whitelist_clients, []},
    {blacklist_peers, []},
    {whitelist_peers, []},

    % Optional modules configuration
    {modules, #{}}
  ]},

  {syn, [
    {scopes, [rooms]}
  ]},

  {mnesia, [
    {dir, "/var/lib/rtp/mnesia"}
  ]},

  {n2o, [
    {port, 8081}
  ]}
].
